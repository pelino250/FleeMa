# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variable files (contain sensitive data)
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Terraform directories
.terraform/
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Environment-specific
.env
.env.local
